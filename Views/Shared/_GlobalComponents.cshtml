<!-- #loadingOverlay: Pantalla corporativa de bloqueo con spinner centrado -->
<div id="loadingOverlay" class="loading-overlay d-none">
    <div class="spinner-border" role="status">
        <span class="visually-hidden">Cargando...</span>
    </div>
    <div class="mt-3 text-white loading-text fw-light" style="letter-spacing: 2px; font-size: 0.9rem;">
        POR FAVOR, ESPERE
    </div>
</div>
