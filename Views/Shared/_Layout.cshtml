<!DOCTYPE html>
<html lang="es">

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <!-- FontAwesome para iconos basicos -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>

<body>

    <header>
        <div class="header-container mb-4">
            <div class="brand-wrapper">
                <img src="~/images/logoElecnor.png" alt="Elecnor" class="header-logo" loading="lazy" />

                <!-- Título centrado en la cabecera -->
                <h1 class="page-title">Informes Comerciales</h1>

                <div class="user-info-header">
                    <span id="lblNombreUsuario" class="me-2 fw-bold">...</span>
                    <button id="btnLogout" class="btn btn-link btn-sm text-decoration-none p-0" 
                            aria-label="Cerrar sesión" title="Cerrar sesión">
                        <i class="fas fa-power-off" aria-hidden="true"></i>
                    </button>
                </div>
            </div>
        </div>
    </header>

    <div class="container">

        <!-- Renderizar Componentes Globales -->
        @await Html.PartialAsync("_GlobalComponents")

        <main role="main" class="pb-3">
            @RenderBody()
        </main>

    </div>

    @* <footer class="border-top footer text-muted mt-auto">

    <div class="container py-3">
    &copy; 2026 - elecnor_informes_comerciales
    </div>

    </footer> *@

    <!-- Dependencias base -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.js"></script>

    <!-- Scripts customizados -->
    <script type="module" src="~/js/site.js" asp-append-version="true"></script>
    <!-- Sección opcional para scripts específicos de cada vista -->
    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>
