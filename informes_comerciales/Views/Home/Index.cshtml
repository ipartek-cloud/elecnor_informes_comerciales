@{
    ViewData["Title"] = "Informes Comerciales";
    int defaultMonth = DateTime.Now.Month == 1 ? 1 : DateTime.Now.Month - 1;
}

<div class="container-fluid">
    <div id="mainContent" class="d-none">
        
        <!-- ==================== FILTROS DE INFORME ==================== -->
        <div class="rpt-filters-container py-2 px-3 bg-light bg-opacity-50 rounded">
            <div class="row g-3 align-items-center justify-content-start rpt-filters-row">
                <div class="col-auto">
                    <label for="txtAnno" class="col-form-label fw-bold">Año</label>
                </div>
                <div class="col-auto">
                    <input type="number" class="form-control text-center" id="txtAnno" name="txtAnno" min="2000" max="2100"
                        value="@DateTime.Now.Year" aria-label="Seleccionar año de consulta">
                </div>
                <div class="col-auto">
                    <label for="txtMes" class="col-form-label fw-bold">Mes</label>
                </div>
                <div class="col-auto">
                    <select class="form-control" id="txtMes" name="txtMes" aria-label="Seleccionar mes de consulta">
                        <option value="1" selected="@(defaultMonth == 1 ? "selected" : null)">Enero</option>
                        <option value="2" selected="@(defaultMonth == 2 ? "selected" : null)">Febrero</option>
                        <option value="3" selected="@(defaultMonth == 3 ? "selected" : null)">Marzo</option>
                        <option value="4" selected="@(defaultMonth == 4 ? "selected" : null)">Abril</option>
                        <option value="5" selected="@(defaultMonth == 5 ? "selected" : null)">Mayo</option>
                        <option value="6" selected="@(defaultMonth == 6 ? "selected" : null)">Junio</option>
                        <option value="7" selected="@(defaultMonth == 7 ? "selected" : null)">Julio</option>
                        <option value="8" selected="@(defaultMonth == 8 ? "selected" : null)">Agosto</option>
                        <option value="9" selected="@(defaultMonth == 9 ? "selected" : null)">Septiembre</option>
                        <option value="10" selected="@(defaultMonth == 10 ? "selected" : null)">Octubre</option>
                        <option value="11" selected="@(defaultMonth == 11 ? "selected" : null)">Noviembre</option>
                        <option value="12" selected="@(defaultMonth == 12 ? "selected" : null)">Diciembre</option>
                    </select>
                </div>
                <div class="col-auto">
                    <div class="d-flex align-items-center" style="height: 38px; gap: 6px;">
                        <label class="fw-bold mb-0" for="chkGenerarHtmlPortable" style="cursor: pointer; font-size: 0.9rem;">
                            HTML Portable
                        </label>
                        <input class="form-check-input" type="checkbox" id="chkGenerarHtmlPortable" name="chkGenerarHtmlPortable"
                               style="cursor: pointer; margin: 0;" aria-label="Generar informe HTML portable (offline)">
                    </div>
                </div>

            </div>
        </div>

        <!-- ==================== NAVEGACIÓN POR PESTAÑAS (TABS) ==================== -->
        <ul class="nav nav-tabs rpt-nav-tabs" id="reportTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="consejo-tab" data-bs-toggle="tab" data-bs-target="#consejo-pane" 
                        type="button" role="tab" aria-controls="consejo-pane" aria-selected="true">
                    CONSEJO ELECNOR
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="comite-tab" data-bs-toggle="tab" data-bs-target="#comite-pane" 
                        type="button" role="tab" aria-controls="comite-pane" aria-selected="false">
                    COMITÉ
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="direcciones-tab" data-bs-toggle="tab" data-bs-target="#direcciones-pane" 
                        type="button" role="tab" aria-controls="direcciones-pane" aria-selected="false">
                    DIRECCIONES GENERALES
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="gerentes-tab" data-bs-toggle="tab" data-bs-target="#gerentes-pane" 
                        type="button" role="tab" aria-controls="gerentes-pane" aria-selected="false">
                    GERENTES ACTIVIDAD
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="opciones-tab" data-bs-toggle="tab" data-bs-target="#opciones-pane" 
                        type="button" role="tab" aria-controls="opciones-pane" aria-selected="false">
                    OPCIONES DE GENERACIÓN
                </button>
            </li>
        </ul>

        <div class="tab-content rpt-tab-content" id="reportTabsContent">
            
            <!-- PESTAÑA 1: CONSEJO ELECNOR -->
            <div class="tab-pane fade show active rpt-tab-pane" id="consejo-pane" role="tabpanel" aria-labelledby="consejo-tab" tabindex="0">
                <div class="card border-0">
                    <div class="card-body p-0">
                        <div id="consejoAdministracionContainer" class="row g-3 p-3 w-100">
                            
                            <!-- COLUMNA IZQUIERDA: INFORME -->
                            <div class="col-md-6 d-flex flex-column gap-2" id="consejoInformeCol">
                                <div class="rpt-header-index-col--blue text-center w-100 mb-1">
                                    Informe
                                </div>
                                
                                <!-- Mercado-AI-Cart. Producción-Cart. Diferida (Pág. 1) -->
                                <div class="input-group rpt-input-group-index w-100">
                                    <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                            onclick="cargarInforme(this, 'cartera_diferida_consejo')"
                                            data-input-pag="inputPaginaCartera"
                                            aria-label="Ver informe Mercado-AI-Cart. Producción-Cart. Diferida" data-informe-tipo="CONSEJO ELECNOR" data-informe-nombre="Mercado-AI-Cart. Producción-Cart. Diferida">
                                        Mercado-AI-Cart. Producción-Cart. Diferida
                                    </button>
                                    <input type="number" class="form-control rpt-input-page"
                                           id="inputPaginaCartera"
                                           name="inputPaginaCartera" value="1" min="0"
                                           aria-label="Página" title="Página inicial">
                                </div>

                                <!-- Mercado-Direcciones Generales-Unidades Negocio (Pág. 2) -->
                                <div class="input-group rpt-input-group-index w-100">
                                    <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                            onclick="cargarInforme(this, 'mercados')"
                                            data-input-pag="inputPaginaMercados"
                                            aria-label="Ver informe Mercado-Direcciones Generales-Unidades Negocio" data-informe-tipo="CONSEJO ELECNOR" data-informe-nombre="Mercado-Direcciones Generales-Unidades Negocio">
                                        Mercado-Direcciones Generales-Unidades Negocio
                                    </button>
                                    <input type="number" class="form-control rpt-input-page"
                                           id="inputPaginaMercados"
                                           name="inputPaginaMercados" value="2" min="0"
                                           aria-label="Página" title="Página inicial">
                                </div>

                                <!-- Países (Pág. 3) -->
                                <div class="input-group rpt-input-group-index w-100">
                                    <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                            onclick="cargarInforme(this, 'paises')"
                                            data-umbral="100000"
                                            data-numeropaises="0"
                                            data-input-pag="inputPaginaPaisesRelevantes"
                                            aria-label="Ver informe Países" data-informe-tipo="CONSEJO ELECNOR" data-informe-nombre="Países">
                                        Países
                                    </button>
                                    <input type="number" class="form-control rpt-input-page"
                                           id="inputPaginaPaisesRelevantes"
                                           name="inputPaginaPaisesRelevantes" value="3" min="0"
                                           aria-label="Página" title="Página inicial">
                                </div>

                                <!-- Actividades (Pág. 4) -->
                                <div class="input-group rpt-input-group-index w-100">
                                    <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                            onclick="cargarInforme(this, 'actividades')"
                                            data-input-pag="inputPaginaActividades"
                                            aria-label="Ver informe Actividades" data-informe-tipo="CONSEJO ELECNOR" data-informe-nombre="Actividades">
                                        Actividades
                                    </button>
                                    <input type="number" class="form-control rpt-input-page" 
                                           id="inputPaginaActividades" 
                                           name="inputPaginaActividades" value="4" min="0" 
                                           aria-label="Página" title="Página inicial">
                                </div>

                                <!-- Principales Contrataciones Nacionales - Internacionales (Pág. 5) -->
                                <div class="input-group rpt-input-group-index w-100">
                                    <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                            onclick="cargarInforme(this, 'contrataciones')"
                                            data-input-pag="inputPaginaContrataciones"
                                            data-umbral1="5000"
                                            data-umbral2="15000"
                                            data-umbral3="10000"
                                            data-umbral4="25000"
                                            aria-label="Ver informe Principales Contrataciones Nacionales - Internacionales" data-informe-tipo="CONSEJO ELECNOR" data-informe-nombre="Principales Contrataciones Nacionales - Internacionales">
                                        Principales Contrataciones Nacionales - Internacionales
                                    </button>
                                    <input type="number" class="form-control rpt-input-page"
                                           id="inputPaginaContrataciones"
                                           name="inputPaginaContrataciones" value="5" min="0"
                                           aria-label="Página" title="Página inicial">
                                </div>

                                <!-- Contratación Asociada a Inversión (Pág. 6) -->
                                <div class="input-group rpt-input-group-index w-100">
                                    <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                            onclick="cargarInforme(this, 'contrataciones_ai')"
                                             data-input-pag="inputPaginaContratacionesAI"
                                             data-umbral1="0,3"
                                             data-umbral2="0,7"
                                             aria-label="Ver informe Contratación Asociada a Inversión" data-informe-tipo="CONSEJO ELECNOR" data-informe-nombre="Contratación Asociada a Inversión">
                                        Contratación Asociada a Inversión
                                    </button>
                                    <input type="number" class="form-control rpt-input-page"
                                           id="inputPaginaContratacionesAI"
                                           name="inputPaginaContratacionesAI" value="6" min="0"
                                           aria-label="Página" title="Página inicial">
                                </div>

                                <!-- Ranking Clientes Nacionales (Pág. 7) -->
                                <div class="input-group rpt-input-group-index w-100">
                                    <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                            onclick="cargarInforme(this, 'ranking_contratacion_clientes')"
                                            data-input-pag="inputPaginaRankingClientesNacionales"
                                            data-mercado="Nacional"
                                            aria-label="Ver informe Ranking Clientes Nacionales" data-informe-tipo="CONSEJO ELECNOR" data-informe-nombre="Ranking Clientes Nacionales">
                                        Ranking Clientes Nacionales
                                    </button>
                                    <input type="number" class="form-control rpt-input-page"
                                           id="inputPaginaRankingClientesNacionales"
                                           name="inputPaginaRankingClientesNacionales" value="7" min="0"
                                           aria-label="Página" title="Página inicial">
                                </div>

                                <!-- Ranking Clientes Internacionales (Pág. 8) -->
                                <div class="input-group rpt-input-group-index w-100">
                                    <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                            onclick="cargarInforme(this, 'ranking_contratacion_clientes')"
                                            data-input-pag="inputPaginaRankingClientesInternacionales"
                                            data-mercado="Internacional"
                                            aria-label="Ver informe Ranking Clientes Internacionales" data-informe-tipo="CONSEJO ELECNOR" data-informe-nombre="Ranking Clientes Internacionales">
                                        Ranking Clientes Internacionales
                                    </button>
                                    <input type="number" class="form-control rpt-input-page"
                                           id="inputPaginaRankingClientesInternacionales"
                                           name="inputPaginaRankingClientesInternacionales" value="8" min="0"
                                           aria-label="Página" title="Página inicial">
                                </div>

                            </div>
                            
                            <!-- COLUMNA DERECHA: ANEXO -->
                            <div class="col-md-6 d-flex flex-column gap-2" id="consejoAnexoCol">
                                <div class="rpt-header-index-col--blue text-center w-100 mb-1">
                                    Anexo
                                </div>

                                <!-- Cartera Diferida DG Servicios - DG Proyectos (Pág. 1, Pendiente) -->
                                <div class="input-group rpt-input-group-index w-100">
                                    <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                            style="background-color: #e3f2fd;"
                                            onclick="Swal.fire({ title: 'Informe Pendiente', text: 'El informe Cartera Diferida DG Servicios - DG Proyectos está pendiente de desarrollo.', icon: 'info', confirmButtonColor: '#005596' })"
                                            aria-label="Cartera Diferida DG Servicios - DG Proyectos (Pendiente)">
                                        Cartera Diferida DG Servicios - DG Proyectos
                                    </button>
                                    <input type="number" class="form-control rpt-input-page" id="inputPaginaCarteraDG" name="inputPaginaCarteraDG" value="1" min="0" aria-label="Página" style="background-color: #e3f2fd;">
                                </div>

                                <!-- Cartera Diferida Mercados - Clientes (Pág. 2, Pendiente) -->
                                <div class="input-group rpt-input-group-index w-100">
                                    <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                            style="background-color: #e3f2fd;"
                                            onclick="Swal.fire({ title: 'Informe Pendiente', text: 'El informe Cartera Diferida Mercados - Clientes está pendiente de desarrollo.', icon: 'info', confirmButtonColor: '#005596' })"
                                            aria-label="Cartera Diferida Mercados - Clientes (Pendiente)">
                                        Cartera Diferida Mercados - Clientes
                                    </button>
                                    <input type="number" class="form-control rpt-input-page" id="inputPaginaCarteraMercados" name="inputPaginaCarteraMercados" value="2" min="0" aria-label="Página" style="background-color: #e3f2fd;">
                                </div>

                                <!-- Todos los Países (Pág. 3) -->
                                <div class="input-group rpt-input-group-index w-100">
                                    <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                            onclick="cargarInforme(this, 'paises')"
                                            data-umbral="0"
                                            data-numeropaises="0"
                                            data-input-pag="inputPaginaPaises"
                                            aria-label="Ver informe Todos los Países" data-informe-tipo="CONSEJO ELECNOR" data-informe-nombre="Todos los Países">
                                        Todos los Países
                                    </button>
                                    <input type="number" class="form-control rpt-input-page"
                                           id="inputPaginaPaises"
                                           name="inputPaginaPaises" value="3" min="0"
                                           aria-label="Página" title="Página inicial">
                                </div>

                                <!-- Mercado Internacional DG - Países (Pág. 4, Pendiente) -->
                                <div class="input-group rpt-input-group-index w-100">
                                    <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                            style="background-color: #e3f2fd;"
                                            onclick="Swal.fire({ title: 'Informe Pendiente', text: 'El informe Mercado Internacional DG - Países está pendiente de desarrollo.', icon: 'info', confirmButtonColor: '#005596' })"
                                            aria-label="Mercado Internacional DG - Países (Pendiente)">
                                        Mercado Internacional DG - Países
                                    </button>
                                    <input type="number" class="form-control rpt-input-page" id="inputPaginaMercadoIntDG" name="inputPaginaMercadoIntDG" value="4" min="0" aria-label="Página" style="background-color: #e3f2fd;">
                                </div>

                                <!-- Mercado Internacional DG - Elecnor Value (Pág. 5, Pendiente) -->
                                <div class="input-group rpt-input-group-index w-100">
                                    <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                            style="background-color: #e3f2fd;"
                                            onclick="Swal.fire({ title: 'Informe Pendiente', text: 'El informe Mercado Internacional DG - Elecnor Value está pendiente de desarrollo.', icon: 'info', confirmButtonColor: '#005596' })"
                                            aria-label="Mercado Internacional DG - Elecnor Value (Pendiente)">
                                        Mercado Internacional DG - Elecnor Value
                                    </button>
                                    <input type="number" class="form-control rpt-input-page" id="inputPaginaMercadoIntValue" name="inputPaginaMercadoIntValue" value="5" min="0" aria-label="Página" style="background-color: #e3f2fd;">
                                </div>

                                <!-- Contratación Significativa Nacional DG Servicios (Pág. 6) -->
                                <div class="input-group rpt-input-group-index w-100">
                                    <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                            onclick="cargarInforme(this, 'contrataciones_significativas')"
                                            data-input-pag="inputPaginaContratacionesSignificativasNacionalesServicios"
                                            data-mercado="Nacional"
                                            data-subdireccion="221"
                                            data-limiteimporte="1000"
                                            aria-label="Ver informe Contratación Significativa Nacional DG Servicios" data-informe-tipo="CONSEJO ELECNOR" data-informe-nombre="Contratación Significativa Nacional DG Servicios">
                                        Contratación Significativa Nacional DG Servicios
                                    </button>
                                    <input type="number" class="form-control rpt-input-page"
                                           id="inputPaginaContratacionesSignificativasNacionalesServicios"
                                           name="inputPaginaContratacionesSignificativasNacionalesServicios" value="6" min="0"
                                           aria-label="Página" title="Página inicial">
                                </div>

                                <!-- Contratación Significativa Nacional DG Proyectos (Pág. 7) -->
                                <div class="input-group rpt-input-group-index w-100">
                                    <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                            onclick="cargarInforme(this, 'contrataciones_significativas')"
                                            data-input-pag="inputPaginaContratacionesSignificativasNacionalesProyectos"
                                            data-mercado="Nacional"
                                            data-subdireccion="286"
                                            data-limiteimporte="1000"
                                            aria-label="Ver informe Contratación Significativa Nacional DG Proyectos" data-informe-tipo="CONSEJO ELECNOR" data-informe-nombre="Contratación Significativa Nacional DG Proyectos">
                                        Contratación Significativa Nacional DG Proyectos
                                    </button>
                                    <input type="number" class="form-control rpt-input-page" 
                                           id="inputPaginaContratacionesSignificativasNacionalesProyectos" 
                                           name="inputPaginaContratacionesSignificativasNacionalesProyectos" value="7" min="0" 
                                           aria-label="Página">
                                </div>

                                <!-- Contratación Significativa Internacional DG Servicios (Pág. 8) -->
                                <div class="input-group rpt-input-group-index w-100">
                                    <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                            onclick="cargarInforme(this, 'contrataciones_significativas')"
                                            data-input-pag="inputPaginaContratacionesSignificativasInternacionalesServicios"
                                            data-mercado="Internacional"
                                            data-subdireccion="221"
                                            data-limiteimporte="1000"
                                            aria-label="Ver informe Contratación Significativa Internacional DG Servicios" data-informe-tipo="CONSEJO ELECNOR" data-informe-nombre="Contratación Significativa Internacional DG Servicios">
                                        Contratación Significativa Internacional DG Servicios
                                    </button>
                                    <input type="number" class="form-control rpt-input-page"
                                           id="inputPaginaContratacionesSignificativasInternacionalesServicios"
                                           name="inputPaginaContratacionesSignificativasInternacionalesServicios" value="8" min="0"
                                           aria-label="Página" title="Página inicial">
                                </div>

                                <!-- Contratación Significativa Internacional DG Proyectos (Pág. 9) -->
                                <div class="input-group rpt-input-group-index w-100">
                                    <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                            onclick="cargarInforme(this, 'contrataciones_significativas')"
                                            data-input-pag="inputPaginaContratacionesSignificativasInternacionalesProyectos"
                                            data-mercado="Internacional"
                                            data-subdireccion="286"
                                            data-limiteimporte="1000"
                                            aria-label="Ver informe Contratación Significativa Internacional DG Proyectos" data-informe-tipo="CONSEJO ELECNOR" data-informe-nombre="Contratación Significativa Internacional DG Proyectos">
                                        Contratación Significativa Internacional DG Proyectos
                                    </button>
                                    <input type="number" class="form-control rpt-input-page" 
                                           id="inputPaginaContratacionesSignificativasInternacionalesProyectos" 
                                           name="inputPaginaContratacionesSignificativasInternacionalesProyectos" value="9" min="0" 
                                           aria-label="Página">
                                </div>

                            </div>

                        </div>
                    </div>
                </div>
            </div>

            <!-- PESTAÑA 2: COMITÉ -->
                        <div class="tab-pane fade rpt-tab-pane" id="comite-pane" role="tabpanel" aria-labelledby="comite-tab" tabindex="0">
                <div class="card border-0">
                    <div class="card-body p-0">
                        <div id="reportButtonsContainer" class="row g-3 p-3 w-100">
                            
                            <!-- COLUMNA IZQUIERDA: COMITÉ ELECNOR -->
                            <div class="col-md-6 d-flex flex-column gap-2" id="comiteElecnorCol">
                                <div class="rpt-header-index-col--blue text-center w-100 mb-1">
                                    Comité Elecnor
                                </div>

                                <!-- Mercados -->
                                <div class="input-group rpt-input-group-index w-100">
                                     <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                             onclick="cargarInforme(this, 'mercados_dg')"
                                             data-mostrar-titulo="true"
                                             data-input-pag="inputPaginaComiteMercados"
                                            aria-label="Ver informe Mercado-Direcciones Generales-Unidades Negocio" data-informe-tipo="COMITÉ" data-informe-nombre="Mercado-Direcciones Generales-Unidades Negocio">
                                         Mercado-Direcciones Generales-Unidades Negocio
                                     </button>
                                     <input type="number" class="form-control rpt-input-page"
                                            id="inputPaginaComiteMercados"
                                            name="inputPaginaComiteMercados" value="1" min="0"
                                            aria-label="Página" title="Página inicial">
                                </div>

                                <!-- Gerencias -->
                                <div class="input-group rpt-input-group-index w-100">
                                    <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                             onclick="cargarInforme(this, 'gerencias')"
                                             data-mostrar-titulo="true"
                                             data-input-pag="inputPaginaGerencias"
                                             aria-label="Ver informe Gerencias DG Servicios" data-informe-tipo="COMITÉ" data-informe-nombre="Gerencias DG Servicios">
                                        Gerencias DG Servicios
                                    </button>
                                    <input type="number" class="form-control rpt-input-page"
                                            id="inputPaginaGerencias"
                                            name="inputPaginaGerencias" value="2" min="0"
                                            aria-label="Página" title="Página inicial">
                                </div>

                                <!-- Actividades Objetivos -->
                                <div class="input-group rpt-input-group-index w-100">
                                    <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                             onclick="cargarInforme(this, 'actividades_objetivos')"
                                             data-mostrar-titulo="true"
                                             data-input-pag="inputPaginaActividadesObjetivos"
                                             aria-label="Ver informe Actividades" data-informe-tipo="COMITÉ" data-informe-nombre="Actividades">
                                        Actividades
                                    </button>
                                    <input type="number" class="form-control rpt-input-page"
                                            id="inputPaginaActividadesObjetivos"
