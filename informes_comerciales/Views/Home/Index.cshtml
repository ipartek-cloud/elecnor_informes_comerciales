@{
    ViewData["Title"] = "Informes Consejo";
    int defaultMonth = DateTime.Now.Month == 1 ? 1 : DateTime.Now.Month - 1;
}

<div class="container-fluid">
    <div id="mainContent" class="d-none">
        
        <!-- ==================== CARD 1: FILTROS DE INFORME ==================== -->
        <div class="card mb-4 rpt-index-card">
            <div class="card-header rpt-index-header text-center">
                <h5 class="mb-0" style="font-family: Verdana;">Filtros</h5>
            </div>
            <div class="card-body">
                <div class="row g-3 align-items-center">
                    <div class="col-auto">
                        <label for="txtAnno" class="col-form-label fw-bold">Año</label>
                    </div>
                    <div class="col-auto">
                        <input type="number" class="form-control" id="txtAnno" name="txtAnno" min="2000" max="2100"
                            value="@DateTime.Now.Year" aria-label="Seleccionar año de consulta">
                    </div>
                    <div class="col-auto">
                        <label for="txtMes" class="col-form-label fw-bold">Mes</label>
                    </div>
                    <div class="col-auto">
                        <select class="form-control" id="txtMes" name="txtMes" aria-label="Seleccionar mes de consulta">
                            <option value="1" selected="@(defaultMonth == 1 ? "selected" : null)">Enero</option>
                            <option value="2" selected="@(defaultMonth == 2 ? "selected" : null)">Febrero</option>
                            <option value="3" selected="@(defaultMonth == 3 ? "selected" : null)">Marzo</option>
                            <option value="4" selected="@(defaultMonth == 4 ? "selected" : null)">Abril</option>
                            <option value="5" selected="@(defaultMonth == 5 ? "selected" : null)">Mayo</option>
                            <option value="6" selected="@(defaultMonth == 6 ? "selected" : null)">Junio</option>
                            <option value="7" selected="@(defaultMonth == 7 ? "selected" : null)">Julio</option>
                            <option value="8" selected="@(defaultMonth == 8 ? "selected" : null)">Agosto</option>
                            <option value="9" selected="@(defaultMonth == 9 ? "selected" : null)">Septiembre</option>
                            <option value="10" selected="@(defaultMonth == 10 ? "selected" : null)">Octubre</option>
                            <option value="11" selected="@(defaultMonth == 11 ? "selected" : null)">Noviembre</option>
                            <option value="12" selected="@(defaultMonth == 12 ? "selected" : null)">Diciembre</option>
                        </select>
                    </div>
                    <div class="col-auto ms-auto">
                        <label for="inputLimiteMonto" class="col-form-label fw-bold">Límite Monto (miles)</label>
                    </div>
                    <div class="col-auto">
                        <input type="number" class="form-control" id="inputLimiteMonto" name="inputLimiteMonto" 
                               value="15000" step="1000" style="width: 120px;" aria-label="Límite de monto">
                    </div>
                    <div class="col-auto">
                        <label for="cmbSubDireccionGeneral" class="col-form-label fw-bold">SubDirección</label>
                    </div>
                    <div class="col-auto">
                        <select class="form-control rpt-combo-subdireccion" id="cmbSubDireccionGeneral" name="cmbSubDireccionGeneral" 
                                style="min-width: 250px;" aria-label="Seleccionar SubDirección General">
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- ==================== CARD 2: CONSEJO ELECNOR ==================== -->
        <div class="card mb-4 rpt-index-card">
            <div class="card-header rpt-index-header text-center">
                <h5 class="mb-0" style="font-family: Verdana;">CONSEJO ELECNOR</h5>
            </div>
            <div class="card-body p-0">
                <div id="consejoAdministracionContainer" class="d-flex flex-column gap-2 align-items-start p-3">
                    
                    <!-- ENCABEZADOS DE COLUMNA -->
                    <div class="d-flex align-items-center gap-2 w-100 mb-2">
                        <div class="input-group rpt-input-group-index flex-fill">
                            <div class="rpt-header-index-col text-center w-100">
                                Informe
                            </div>
                        </div>
                        <div class="input-group rpt-input-group-index flex-fill">
                            <div class="rpt-header-index-col text-center w-100">
                                Anexo
                            </div>
                        </div>
                    </div>

                    <!-- FILA 1 -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <!-- Cartera Diferida -->
                        <div class="input-group rpt-input-group-index flex-fill">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'cartera_diferida_consejo')"
                                    data-input-pag="inputPaginaCartera"
                                    aria-label="Ver informe Mercado-AI-Cart. Producción-Cart. Diferida">
                                Mercado-AI-Cart. Producción-Cart. Diferida
                            </button>
                            <input type="number" class="form-control rpt-input-page"
                                   id="inputPaginaCartera"
                                   name="inputPaginaCartera" value="1" min="1"
                                   aria-label="Página" title="Página inicial">
                        </div>
                        <!-- Cartera Diferida DG Servicios -->
                        <div class="input-group rpt-input-group-index flex-fill">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    style="background-color: #e3f2fd;"
                                    onclick="Swal.fire({ title: 'Informe Pendiente', text: 'El informe Cartera Diferida DG Servicios - DG Proyectos está pendiente de desarrollo.', icon: 'info', confirmButtonColor: '#005596' })"
                                    aria-label="Cartera Diferida DG Servicios - DG Proyectos (Pendiente)">
                                Cartera Diferida DG Servicios - DG Proyectos
                            </button>
                            <input type="number" class="form-control rpt-input-page" id="inputPaginaCarteraDG" name="inputPaginaCarteraDG" value="1" min="1" aria-label="Página">
                        </div>
                    </div>

                    <!-- FILA 2 -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <!-- Mercados -->
                        <div class="input-group rpt-input-group-index flex-fill">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'mercados')"
                                    data-input-pag="inputPaginaMercados"
                                    aria-label="Ver informe Mercado-Direcciones Generales-Unidades Negocio">
                                Mercado-Direcciones Generales-Unidades Negocio
                            </button>
                            <input type="number" class="form-control rpt-input-page"
                                   id="inputPaginaMercados"
                                   name="inputPaginaMercados" value="2" min="1"
                                   aria-label="Página" title="Página inicial">
                        </div>
                        <!-- Cartera Diferida Mercados -->
                        <div class="input-group rpt-input-group-index flex-fill">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    style="background-color: #e3f2fd;"
                                    onclick="Swal.fire({ title: 'Informe Pendiente', text: 'El informe Cartera Diferida Mercados - Clientes está pendiente de desarrollo.', icon: 'info', confirmButtonColor: '#005596' })"
                                    aria-label="Cartera Diferida Mercados - Clientes (Pendiente)">
                                Cartera Diferida Mercados - Clientes
                            </button>
                            <input type="number" class="form-control rpt-input-page" id="inputPaginaCarteraMercados" name="inputPaginaCarteraMercados" value="2" min="1" aria-label="Página">
                        </div>
                    </div>

                    <!-- FILA 3 -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <!-- Países Relevantes -->
                        <div class="input-group rpt-input-group-index flex-fill">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'paises')"
                                    data-umbral="100000"
                                    data-input-pag="inputPaginaPaisesRelevantes"
                                    aria-label="Ver informe Países">
                                Países
                            </button>
                            <input type="number" class="form-control rpt-input-page"
                                   id="inputPaginaPaisesRelevantes"
                                   name="inputPaginaPaisesRelevantes" value="3" min="1"
                                   aria-label="Página" title="Página inicial">
                        </div>
                        <!-- Países -->
                        <div class="input-group rpt-input-group-index flex-fill">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'paises')"
                                    data-umbral="0"
                                    data-input-pag="inputPaginaPaises"
                                    aria-label="Ver informe Todos los Países">
                                Todos los Países
                            </button>
                            <input type="number" class="form-control rpt-input-page"
                                   id="inputPaginaPaises"
                                   name="inputPaginaPaises" value="3" min="1"
                                   aria-label="Página" title="Página inicial">
                        </div>
                    </div>

                    <!-- FILA 4 -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <!-- Actividades -->
                        <div class="input-group rpt-input-group-index flex-fill">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'actividades')"
                                    data-input-pag="inputPaginaActividades"
                                    aria-label="Ver informe Actividades">
                                Actividades
                            </button>
                            <input type="number" class="form-control rpt-input-page" 
                                   id="inputPaginaActividades" 
                                   name="inputPaginaActividades" value="4" min="1" 
                                   aria-label="Página" title="Página inicial">
                        </div>
                        <!-- Mercado Internacional DG Países -->
                        <div class="input-group rpt-input-group-index flex-fill">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    style="background-color: #e3f2fd;"
                                    onclick="Swal.fire({ title: 'Informe Pendiente', text: 'El informe Mercado Internacional DG - Países está pendiente de desarrollo.', icon: 'info', confirmButtonColor: '#005596' })"
                                    aria-label="Mercado Internacional DG - Países (Pendiente)">
                                Mercado Internacional DG - Países
                            </button>
                            <input type="number" class="form-control rpt-input-page" id="inputPaginaMercadoIntDG" name="inputPaginaMercadoIntDG" value="4" min="1" aria-label="Página">
                        </div>
                    </div>

                    <!-- FILA 5 -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <!-- Contrataciones -->
                        <div class="input-group rpt-input-group-index flex-fill">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'contrataciones')"
                                    data-input-pag="inputPaginaContrataciones"
                                    aria-label="Ver informe Principales Contrataciones Nacionales - Internacionales">
                                Principales Contrataciones Nacionales - Internacionales
                            </button>
                            <input type="number" class="form-control rpt-input-page"
                                   id="inputPaginaContrataciones"
                                   name="inputPaginaContrataciones" value="5" min="1"
                                   aria-label="Página" title="Página inicial">
                        </div>
                        <!-- Mercado Internacional DG Elecnor Value -->
                        <div class="input-group rpt-input-group-index flex-fill">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    style="background-color: #e3f2fd;"
                                    onclick="Swal.fire({ title: 'Informe Pendiente', text: 'El informe Mercado Internacional DG - Elecnor Value está pendiente de desarrollo.', icon: 'info', confirmButtonColor: '#005596' })"
                                    aria-label="Mercado Internacional DG - Elecnor Value (Pendiente)">
                                Mercado Internacional DG - Elecnor Value
                            </button>
                            <input type="number" class="form-control rpt-input-page" id="inputPaginaMercadoIntValue" name="inputPaginaMercadoIntValue" value="5" min="1" aria-label="Página">
                        </div>
                    </div>

                    <!-- FILA 6 -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <!-- Contrataciones AI -->
                        <div class="input-group rpt-input-group-index flex-fill">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'contrataciones_ai')"
                                    data-input-pag="inputPaginaContratacionesAI"
                                    aria-label="Ver informe Contratación Asociada a Inversión">
                                Contratación Asociada a Inversión
                            </button>
                            <input type="number" class="form-control rpt-input-page"
                                   id="inputPaginaContratacionesAI"
                                   name="inputPaginaContratacionesAI" value="6" min="1"
                                   aria-label="Página" title="Página inicial">
                        </div>
                        <!-- Contrataciones Significativas Nac. -->
                        <div class="input-group rpt-input-group-index flex-fill">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'contrataciones_significativas')"
                                    data-input-pag="inputPaginaContratacionesSignificativasNacionalesServicios"
                                    data-mercado="Nacional"
                                    data-subdireccion="221"
                                    aria-label="Ver informe Contratación Significativa Nacional DG Servicios">
                                Contratación Significativa Nacional DG Servicios
                            </button>
                            <input type="number" class="form-control rpt-input-page"
                                   id="inputPaginaContratacionesSignificativasNacionalesServicios"
                                   name="inputPaginaContratacionesSignificativasNacionalesServicios" value="6" min="1"
                                   aria-label="Página" title="Página inicial">
                        </div>
                    </div>

                    <!-- FILA 7 -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <!-- Ranking Nac. -->
                        <div class="input-group rpt-input-group-index flex-fill">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'ranking_contratacion_clientes')"
                                    data-input-pag="inputPaginaRankingClientesNacionales"
                                    data-mercado="Nacional"
                                    aria-label="Ver informe Ranking Clientes Nacionales">
                                Ranking Clientes Nacionales
                            </button>
                            <input type="number" class="form-control rpt-input-page"
                                   id="inputPaginaRankingClientesNacionales"
                                   name="inputPaginaRankingClientesNacionales" value="7" min="1"
                                   aria-label="Página" title="Página inicial">
                        </div>
                        <!-- Contratación Significativa Nacional DG Proyectos -->
                        <div class="input-group rpt-input-group-index flex-fill">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'contrataciones_significativas')"
                                    data-input-pag="inputPaginaContratacionesSignificativasNacionalesProyectos"
                                    data-mercado="Nacional"
                                    data-subdireccion="286"
                                    aria-label="Ver informe Contratación Significativa Nacional DG Proyectos">
                                Contratación Significativa Nacional DG Proyectos
                            </button>
                            <input type="number" class="form-control rpt-input-page" 
                                   id="inputPaginaContratacionesSignificativasNacionalesProyectos" 
                                   name="inputPaginaContratacionesSignificativasNacionalesProyectos" value="7" min="1" 
                                   aria-label="Página">
                        </div>
                    </div>

                    <!-- FILA 8 -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <!-- Ranking Int. -->
                        <div class="input-group rpt-input-group-index flex-fill">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'ranking_contratacion_clientes')"
                                    data-input-pag="inputPaginaRankingClientesInternacionales"
                                    data-mercado="Internacional"
                                    aria-label="Ver informe Ranking Clientes Internacionales">
                                Ranking Clientes Internacionales
                            </button>
                            <input type="number" class="form-control rpt-input-page"
                                   id="inputPaginaRankingClientesInternacionales"
                                   name="inputPaginaRankingClientesInternacionales" value="8" min="1"
                                   aria-label="Página" title="Página inicial">
                        </div>
                        <!-- Contrataciones Significativas Int. -->
                        <div class="input-group rpt-input-group-index flex-fill">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'contrataciones_significativas')"
                                    data-input-pag="inputPaginaContratacionesSignificativasInternacionalesServicios"
                                    data-mercado="Internacional"
                                    data-subdireccion="221"
                                    aria-label="Ver informe Contratación Significativa Internacional DG Servicios">
                                Contratación Significativa Internacional DG Servicios
                            </button>
                            <input type="number" class="form-control rpt-input-page"
                                   id="inputPaginaContratacionesSignificativasInternacionalesServicios"
                                   name="inputPaginaContratacionesSignificativasInternacionalesServicios" value="8" min="1"
                                   aria-label="Página" title="Página inicial">
                        </div>
                    </div>

                    <!-- FILA 9 -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <!-- Vacío Izquierda (invisible pero ocupa espacio) -->
                        <div class="input-group rpt-input-group-index flex-fill" style="visibility: hidden;"></div>
                        <!-- Contratación Significativa Internacional DG Proyectos -->
                        <div class="input-group rpt-input-group-index flex-fill">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'contrataciones_significativas')"
                                    data-input-pag="inputPaginaContratacionesSignificativasInternacionalesProyectos"
                                    data-mercado="Internacional"
                                    data-subdireccion="286"
                                    aria-label="Ver informe Contratación Significativa Internacional DG Proyectos">
                                Contratación Significativa Internacional DG Proyectos
                            </button>
                            <input type="number" class="form-control rpt-input-page" 
                                   id="inputPaginaContratacionesSignificativasInternacionalesProyectos" 
                                   name="inputPaginaContratacionesSignificativasInternacionalesProyectos" value="9" min="1" 
                                   aria-label="Página">
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- ==================== CARD 3: COMITÉ ==================== -->
        <div class="card mb-4 rpt-index-card">
            <div class="card-header rpt-index-header text-center">
                <h5 class="mb-0" style="font-family: Verdana;">COMITÉ</h5>
            </div>
            <div class="card-body p-0">
                <div id="reportButtonsContainer" class="d-flex flex-column gap-2 align-items-start p-3">
                    
                    <!-- ENCABEZADOS DE COLUMNA -->
                    <div class="d-flex align-items-center gap-2 w-100 mb-2">
                        <div class="input-group rpt-input-group-index flex-fill">
                            <div class="rpt-header-index-col text-center w-100">
                                Comité Elecnor
                            </div>
                        </div>
                        <div class="input-group rpt-input-group-index flex-fill">
                            <div class="rpt-header-index-col text-center w-100">
                                Comité Internacional
                            </div>
                        </div>
                    </div>

                    <!-- FILA 1 -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <!-- Mercados -->
                        <div class="input-group rpt-input-group-index flex-fill">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'mercados_dg')"
                                    data-input-pag="inputPaginaComiteMercados"
                                    aria-label="Ver informe Mercado-Direcciones Generales-Unidades Negocio">
                                Mercado-Direcciones Generales-Unidades Negocio
                            </button>
                            <input type="number" class="form-control rpt-input-page"
                                   id="inputPaginaComiteMercados"
                                   name="inputPaginaComiteMercados" value="1" min="1"
                                   aria-label="Página" title="Página inicial">
                        </div>
                        <!-- Vacío Derecha -->
                        <div class="input-group rpt-input-group-index flex-fill" style="visibility: hidden;"></div>
                    </div>

                    <!-- FILA 2 -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <!-- Gerencias -->
                        <div class="input-group rpt-input-group-index flex-fill">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'gerencias')"
                                    data-input-pag="inputPaginaGerencias"
                                    aria-label="Ver informe Gerencias DG Servicios">
                                Gerencias DG Servicios
                            </button>
                            <input type="number" class="form-control rpt-input-page"
                                   id="inputPaginaGerencias"
                                   name="inputPaginaGerencias" value="2" min="1"
                                   aria-label="Página" title="Página inicial">
                        </div>
                        <!-- Vacío Derecha -->
                        <div class="input-group rpt-input-group-index flex-fill" style="visibility: hidden;"></div>
                    </div>

                    <!-- FILA 3 -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <!-- Actividades Objetivos -->
                        <div class="input-group rpt-input-group-index flex-fill">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'actividades_objetivos')"
                                    data-input-pag="inputPaginaActividadesObjetivos"
                                    aria-label="Ver informe Actividades">
                                Actividades
                            </button>
                            <input type="number" class="form-control rpt-input-page"
                                   id="inputPaginaActividadesObjetivos"
                                   name="inputPaginaActividadesObjetivos" value="3" min="1"
                                   aria-label="Página" title="Página inicial">
                        </div>
                        <!-- Vacío Derecha -->
                        <div class="input-group rpt-input-group-index flex-fill" style="visibility: hidden;"></div>
                    </div>

                    <!-- FILA 4 -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <!-- S.G. DELEGACIONES MERCADOS -->
                        <div class="input-group rpt-input-group-index flex-fill">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'mercados_sg_delegaciones')"
                                    data-input-pag="inputPaginaMercadosSGDelegaciones"
                                    aria-label="Ver informe DG - Unidades Negocio - Delegaciones">
                                DG - Unidades Negocio - Delegaciones
                            </button>
                            <input type="number" class="form-control rpt-input-page"
                                   id="inputPaginaMercadosSGDelegaciones"
                                   name="inputPaginaMercadosSGDelegaciones" value="4" min="1"
                                   aria-label="Página" title="Página inicial">
                        </div>
                        <!-- Vacío Derecha -->
                        <div class="input-group rpt-input-group-index flex-fill" style="visibility: hidden;"></div>
                    </div>

                    <!-- FILA 5 -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <!-- CONTRATACIONES SIGNIFICATIVAS NACIONAL -->
                        <div class="input-group rpt-input-group-index flex-fill">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'contrataciones_significativas_ri')"
                                    data-mercado="Nacional"
                                    data-mostrar-titulo="false"
                                    data-input-pag="inputPaginaContratacionesSignificativasNacionalComite"
                                    aria-label="Ver informe Contrataciones Significativas Nacionales">
                                Contrataciones Significativas Nacionales
                            </button>
                            <input type="number" class="form-control rpt-input-page"
                                   id="inputPaginaContratacionesSignificativasNacionalComite"
                                   name="inputPaginaContratacionesSignificativasNacionalComite" value="5" min="1"
                                   aria-label="Página" title="Página inicial">
                        </div>
                        <!-- Vacío Derecha -->
                        <div class="input-group rpt-input-group-index flex-fill" style="visibility: hidden;"></div>
                    </div>

                    <!-- FILA 6 -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <!-- CONTRATACIONES SIGNIFICATIVAS INTERNACIONAL -->
                        <div class="input-group rpt-input-group-index flex-fill">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'contrataciones_significativas_ri')"
                                    data-mercado="Internacional"
                                    data-mostrar-titulo="false"
                                    data-input-pag="inputPaginaContratacionesSignificativasInternacionalComite"
                                    aria-label="Ver informe Contrataciones Significativas Internacionales">
                                Contrataciones Significativas Internacionales
                            </button>
                            <input type="number" class="form-control rpt-input-page"
                                   id="inputPaginaContratacionesSignificativasInternacionalComite"
                                   name="inputPaginaContratacionesSignificativasInternacionalComite" value="6" min="1"
                                   aria-label="Página" title="Página inicial">
                        </div>
                        <!-- Vacío Derecha -->
                        <div class="input-group rpt-input-group-index flex-fill" style="visibility: hidden;"></div>
                    </div>

                    <!-- FILA 7 -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <!-- RANKING CLIENTES NACIONALES -->
                        <div class="input-group rpt-input-group-index flex-fill">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'ranking_contratacion_clientes')"
                                    data-mercado="Nacional"
                                    data-mostrar-titulo="false"
                                    data-input-pag="inputPaginaRankingNacionalComite"
                                    aria-label="Ver informe Ranking Clientes Nacionales">
                                Ranking Clientes Nacionales
                            </button>
                            <input type="number" class="form-control rpt-input-page"
                                   id="inputPaginaRankingNacionalComite"
                                   name="inputPaginaRankingNacionalComite" value="7" min="1"
                                   aria-label="Página" title="Página inicial">
                        </div>
                        <!-- Vacío Derecha -->
                        <div class="input-group rpt-input-group-index flex-fill" style="visibility: hidden;"></div>
                    </div>

                    <!-- FILA 8 -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <!-- RANKING CLIENTES INTERNACIONALES -->
                        <div class="input-group rpt-input-group-index flex-fill">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'ranking_contratacion_clientes')"
                                    data-mercado="Internacional"
                                    data-mostrar-titulo="false"
                                    data-input-pag="inputPaginaRankingInternacionalComite"
                                    aria-label="Ver informe Ranking Clientes Internacionales">
                                Ranking Clientes Internacionales
                            </button>
                            <input type="number" class="form-control rpt-input-page"
                                   id="inputPaginaRankingInternacionalComite"
                                   name="inputPaginaRankingInternacionalComite" value="8" min="1"
                                   aria-label="Página" title="Página inicial">
                        </div>
                        <!-- Vacío Derecha -->
                        <div class="input-group rpt-input-group-index flex-fill" style="visibility: hidden;"></div>
                    </div>

                    <!-- FILA 9 -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <!-- PAÍSES RELEVANTES -->
                        <div class="input-group rpt-input-group-index flex-fill">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'paises_all')"
                                    data-mostrar-titulo="false"
                                    data-input-pag="inputPaginaPaisesRelevantesComite"
                                    aria-label="Ver informe Ranking Países (Incluye España)">
                                Ranking Países (Incluye España)
                            </button>
                            <input type="number" class="form-control rpt-input-page"
                                   id="inputPaginaPaisesRelevantesComite"
                                   name="inputPaginaPaisesRelevantesComite" value="9" min="1"
                                   aria-label="Página" title="Página inicial">
                        </div>
                        <!-- Vacío Derecha -->
                        <div class="input-group rpt-input-group-index flex-fill" style="visibility: hidden;"></div>
                    </div>

                    <!-- FILA 10 -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <!-- Cartera Contratación (Detalle) Nacional - Internacional -->
                        <div class="input-group rpt-input-group-index flex-fill">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'cartera_contratacion_detalle')"
                                    data-mercado="Todo"
                                    data-limiteimporte="13000"
                                    data-limitepaises="1000"
                                    data-informe="9.1"
                                    data-input-pag="inputPaginaCarteraContratacionDetalle"
                                    aria-label="Ver informe Cartera Contratación (Detalle) Nacional - Internacional">
                                Cartera Contratación (Detalle) Nacional - Internacional
                            </button>
                            <input type="number" class="form-control rpt-input-page"
                                   id="inputPaginaCarteraContratacionDetalle"
                                   name="inputPaginaCarteraContratacionDetalle" value="10" min="1"
                                   aria-label="Página" title="Página inicial">
                        </div>
                        <!-- Vacío Derecha -->
                        <div class="input-group rpt-input-group-index flex-fill" style="visibility: hidden;"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ==================== CARD 4: OPCIONES DE GENERACIÓN ==================== -->
        <div class="card mb-4 rpt-index-card">
            <div class="card-header rpt-index-header">
                <h5 class="mb-0 text-uppercase" style="font-size: 0.85rem; letter-spacing: 1px;">
                    <i class="fas fa-cogs"></i> Opciones de Generación
                </h5>
            </div>
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-center gap-4 w-100 p-3 bg-light bg-opacity-50">
                    <div class="d-flex align-items-center gap-2">
                        <label class="form-check-label mb-0 rpt-checkbox-label text-muted" for="chkGenerarRPTPrincipalesObras">
                            Generar Contratación
                        </label>
                        <input class="form-check-input mt-0" type="checkbox"
                               id="chkGenerarRPTPrincipalesObras"
                               name="chkGenerarRPTPrincipalesObras">
                    </div>

                    <div class="d-flex align-items-center gap-2">
                        <label class="form-check-label mb-0 rpt-checkbox-label text-muted" for="chkGenerarRPTPrincipalesObrasAI">
                            Generar Contratación(AI)
                        </label>
                        <input class="form-check-input mt-0" type="checkbox"
                               id="chkGenerarRPTPrincipalesObrasAI"
                               name="chkGenerarRPTPrincipalesObrasAI">
                    </div>

                    <div class="d-flex align-items-center gap-2">
                        <label class="form-check-label mb-0 rpt-checkbox-label text-muted" for="chkGenerarRPTPrincipalesContrataciones">
                            Generar Contrataciones Significativas
                        </label>
                        <input class="form-check-input mt-0" type="checkbox"
                               id="chkGenerarRPTPrincipalesContrataciones"
                               name="chkGenerarRPTPrincipalesContrataciones">
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- MODAL LOGIN -->
<div class="modal" id="formLogin" tabindex="-1" role="dialog" aria-labelledby="formLoginLabel" aria-hidden="true"
    data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content login-custom-container p-3">
            <form id="loginForm">
                <div class="modal-body">
                    <div id="loginErrorMsg" class="alert alert-danger d-none" role="alert">
                    </div>

                    <div class="mb-4">
                        <label for="txtUser" class="login-label">Usuario:</label>
                        <input type="text" class="form-control login-input" id="txtUser" name="Username" required
                               value="anruiz"
                               aria-label="Nombre de usuario" aria-required="true">
                    </div>

                    <div class="mb-4">
                        <label for="txtPassword" class="login-label">Contraseña:</label>
                        <div class="position-relative">
                            <input type="password" class="form-control login-input pe-5" id="txtPassword" name="Password" 
                                   required
                                   value="Eagle999"
                                   placeholder="Contraseña"
                                   aria-label="Contraseña" aria-required="true">
                            <i class="fas fa-eye password-toggle-icon" id="togglePassword" title="Mostrar/Ocultar contraseña"></i>
                        </div>
                    </div>

                    <div class="mt-2">
                        <button type="submit" class="btn btn-login-custom" aria-label="Entrar al sistema">
                            Entrar
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL INFORME -->
<div class="modal fade" id="modalInforme" tabindex="-1" aria-labelledby="modalInformeLabel" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen">
        <div class="modal-content border-0">
            <div class="modal-header bg-primary text-white shadow-sm py-2 px-4 modal-header-report">
                <div class="d-flex align-items-center gap-2 modal-header-left">
                    <h5 class="modal-title mb-0" id="modalInformeTitulo">Cargando Informe...</h5>
                    <button type="button" class="btn btn-sm btn-outline-light" id="btnExportarPdf"
                            aria-label="Imprimir informe en PDF">
                        <i class="fas fa-file-pdf me-1" aria-hidden="true"></i> Imprimir PDF
                    </button>
                </div>

                <div class="d-flex align-items-center justify-content-center modal-header-center">
                    <div class="d-flex align-items-center d-none" id="ctrlPaginacion">
                        <button type="button" class="btn btn-sm btn-outline-light"
                                id="btnPagAnterior" disabled
                                aria-label="Ir a gerencia anterior" aria-disabled="true">
                            <i class="fas fa-chevron-left" aria-hidden="true"></i>
                        </button>
                        <span id="lblEstadoPaginacion" class="modal-pag-label mx-2"></span>
                        <button type="button" class="btn btn-sm btn-outline-light"
                                id="btnPagSiguiente" disabled
                                aria-label="Ir a siguiente gerencia" aria-disabled="true">
                            <i class="fas fa-chevron-right" aria-hidden="true"></i>
                        </button>
                    </div>
                </div>

                <div class="d-flex align-items-center justify-content-end modal-header-right">
                    <button type="button" class="btn-close btn-close-white"
                            data-bs-dismiss="modal" aria-label="Cerrar modal de informe"></button>
                </div>
            </div>
            <div class="modal-body modal-body-reports" id="modalInformeContenido">
                <div class="d-flex justify-content-center align-items-center h-100">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

