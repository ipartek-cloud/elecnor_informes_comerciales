@{
    ViewData["Title"] = "Informes Consejo";
    int defaultMonth = DateTime.Now.Month == 1 ? 1 : DateTime.Now.Month - 1;
}

<div class="container-fluid">
    <div id="mainContent" class="d-none">
        
        <!-- ==================== CARD 1: FILTROS DE INFORME ==================== -->
        <div class="card mb-4 rpt-index-card">
            <div class="card-header rpt-index-header">
                <h5 class="mb-0"><i class="fas fa-filter"></i> Filtros de Informe</h5>
            </div>
            <div class="card-body">
                <div class="row g-3 align-items-center">
                    <div class="col-auto">
                        <label for="txtAnno" class="col-form-label fw-bold">Año</label>
                    </div>
                    <div class="col-auto">
                        <input type="number" class="form-control" id="txtAnno" name="txtAnno" min="2000" max="2100"
                            value="@DateTime.Now.Year" aria-label="Seleccionar año de consulta">
                    </div>
                    <div class="col-auto">
                        <label for="txtMes" class="col-form-label fw-bold">Mes</label>
                    </div>
                    <div class="col-auto">
                        <select class="form-control" id="txtMes" name="txtMes" aria-label="Seleccionar mes de consulta">
                            <option value="1" selected="@(defaultMonth == 1 ? "selected" : null)">Enero</option>
                            <option value="2" selected="@(defaultMonth == 2 ? "selected" : null)">Febrero</option>
                            <option value="3" selected="@(defaultMonth == 3 ? "selected" : null)">Marzo</option>
                            <option value="4" selected="@(defaultMonth == 4 ? "selected" : null)">Abril</option>
                            <option value="5" selected="@(defaultMonth == 5 ? "selected" : null)">Mayo</option>
                            <option value="6" selected="@(defaultMonth == 6 ? "selected" : null)">Junio</option>
                            <option value="7" selected="@(defaultMonth == 7 ? "selected" : null)">Julio</option>
                            <option value="8" selected="@(defaultMonth == 8 ? "selected" : null)">Agosto</option>
                            <option value="9" selected="@(defaultMonth == 9 ? "selected" : null)">Septiembre</option>
                            <option value="10" selected="@(defaultMonth == 10 ? "selected" : null)">Octubre</option>
                            <option value="11" selected="@(defaultMonth == 11 ? "selected" : null)">Noviembre</option>
                            <option value="12" selected="@(defaultMonth == 12 ? "selected" : null)">Diciembre</option>
                        </select>
                    </div>
                    <div class="col-auto ms-auto">
                        <label for="cmbSubDireccionGeneral" class="col-form-label fw-bold">SubDirección</label>
                    </div>
                    <div class="col-auto">
                        <select class="form-control rpt-combo-subdireccion" id="cmbSubDireccionGeneral" name="cmbSubDireccionGeneral" 
                                style="min-width: 250px;" aria-label="Seleccionar SubDirección General">
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- ==================== CARD 2: CONSEJO DE ADMINISTRACIÓN ==================== -->
        <div class="card mb-4 rpt-index-card">
            <div class="card-header rpt-index-header">
                <h5 class="mb-0"><i class="fas fa-file-invoice"></i> CONSEJO de ADMINISTRACIÓN</h5>
            </div>
            <div class="card-body p-0">
                <div id="consejoAdministracionContainer" class="d-flex flex-column gap-2 align-items-start p-3">
                    
                    <!-- CARTERA -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <div class="input-group rpt-input-group-index">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'cartera_diferida_consejo')"
                                    data-input-pag="inputPaginaCartera"
                                    aria-label="Ver informe Cartera Diferida">
                                Cartera Diferida
                            </button>
                            <input type="number" class="form-control rpt-input-page"
                                   id="inputPaginaCartera"
                                   name="inputPaginaCartera" value="1" min="1"
                                   aria-label="Página" title="Página inicial">
                        </div>
                    </div>

                    <!-- MERCADOS -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <div class="input-group rpt-input-group-index">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'mercados')"
                                    data-input-pag="inputPaginaMercados"
                                    aria-label="Ver informe Mercados">
                                Mercados
                            </button>
                            <input type="number" class="form-control rpt-input-page"
                                   id="inputPaginaMercados"
                                   name="inputPaginaMercados" value="2" min="1"
                                   aria-label="Página" title="Página inicial">
                        </div>
                    </div>

                    <!-- PAISES RELEVANTES + PAISES -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <div class="input-group rpt-input-group-index">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'paises')"
                                    data-umbral="100000"
                                    data-input-pag="inputPaginaPaisesRelevantes"
                                    aria-label="Ver informe Paises Relevantes">
                                Paises Relevantes (Mercado Internacional)
                            </button>
                            <input type="number" class="form-control rpt-input-page"
                                   id="inputPaginaPaisesRelevantes"
                                   name="inputPaginaPaisesRelevantes" value="3" min="1"
                                   aria-label="Página" title="Página inicial">
                        </div>
                        <div class="input-group rpt-input-group-index">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'paises')"
                                    data-umbral="0"
                                    data-input-pag="inputPaginaPaises"
                                    aria-label="Ver informe Paises">
                                Paises (Mercado Internacional)
                            </button>
                            <input type="number" class="form-control rpt-input-page"
                                   id="inputPaginaPaises"
                                   name="inputPaginaPaises" value="3" min="1"
                                   aria-label="Página" title="Página inicial">
                        </div>
                    </div>

                    <!-- ACTIVIDADES -->
                    <div class="input-group rpt-input-group-index">
                        <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                onclick="cargarInforme(this, 'actividades')"
                                data-input-pag="inputPaginaActividades"
                                aria-label="Ver informe Actividades">
                            Actividades
                        </button>
                        <input type="number" class="form-control rpt-input-page" 
                               id="inputPaginaActividades" 
                               name="inputPaginaActividades" value="4" min="1" 
                               aria-label="Página" title="Página inicial">
                    </div>

                    <!-- CONTRATACIONES + CONTRATACIONES AI -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <div class="input-group rpt-input-group-index">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'contrataciones')"
                                    data-input-pag="inputPaginaContrataciones"
                                    aria-label="Ver informe Contrataciones">
                                Contrataciones
                            </button>
                            <input type="number" class="form-control rpt-input-page"
                                   id="inputPaginaContrataciones"
                                   name="inputPaginaContrataciones" value="5" min="1"
                                   aria-label="Página" title="Página inicial">
                        </div>
                        <div class="input-group rpt-input-group-index">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'contrataciones_ai')"
                                    data-input-pag="inputPaginaContratacionesAI"
                                    aria-label="Ver informe Contrataciones AI">
                                Contrataciones AI
                            </button>
                            <input type="number" class="form-control rpt-input-page"
                                   id="inputPaginaContratacionesAI"
                                   name="inputPaginaContratacionesAI" value="6" min="1"
                                   aria-label="Página" title="Página inicial">
                        </div>
                    </div>

                    <!-- RANKING NACIONAL + INTERNACIONAL -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <div class="input-group rpt-input-group-index">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'ranking_contratacion_clientes')"
                                    data-input-pag="inputPaginaRankingClientesNacionales"
                                    data-mercado="Nacional"
                                    aria-label="Ver informe Ranking Contratación Clientes Nacionales">
                                Ranking Contratación Nacional
                            </button>
                            <input type="number" class="form-control rpt-input-page"
                                   id="inputPaginaRankingClientesNacionales"
                                   name="inputPaginaRankingClientesNacionales" value="7" min="1"
                                   aria-label="Página" title="Página inicial">
                        </div>
                        <div class="input-group rpt-input-group-index">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'ranking_contratacion_clientes')"
                                    data-input-pag="inputPaginaRankingClientesInternacionales"
                                    data-mercado="Internacional"
                                    aria-label="Ver informe Ranking Contratación Clientes Internacionales">
                                Ranking Contratación Internacional
                            </button>
                            <input type="number" class="form-control rpt-input-page"
                                   id="inputPaginaRankingClientesInternacionales"
                                   name="inputPaginaRankingClientesInternacionales" value="8" min="1"
                                   aria-label="Página" title="Página inicial">
                        </div>
                    </div>

                    <!-- CONTRATACIONES SIGNIFICATIVAS NAC. + INT. -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <div class="input-group rpt-input-group-index">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'contrataciones_significativas')"
                                    data-input-pag="inputPaginaContratacionesSignificativasNacionales"
                                    data-mercado="Nacional"
                                    aria-label="Ver informe Contrataciones Significativas Nacional">
                                Contrataciones Significativas Nacional
                            </button>
                            <input type="number" class="form-control rpt-input-page"
                                   id="inputPaginaContratacionesSignificativasNacionales"
                                   name="inputPaginaContratacionesSignificativasNacionales" value="9" min="1"
                                   aria-label="Página" title="Página inicial">
                        </div>
                        <div class="input-group rpt-input-group-index">
                            <button class="btn rpt-btn-light rpt-btn-index flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'contrataciones_significativas')"
                                    data-input-pag="inputPaginaContratacionesSignificativasInternacionales"
                                    data-mercado="Internacional"
                                    aria-label="Ver informe Contrataciones Significativas Internacional">
                                Contrataciones Significativas Internacional
                            </button>
                            <input type="number" class="form-control rpt-input-page"
                                   id="inputPaginaContratacionesSignificativasInternacionales"
                                   name="inputPaginaContratacionesSignificativasInternacionales" value="10" min="1"
                                   aria-label="Página" title="Página inicial">
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- ==================== CARD 3: RESTO DE INFORMES ==================== -->
        <div class="card mb-4 rpt-index-card">
            <div class="card-header rpt-index-header">
                <h5 class="mb-0"><i class="fas fa-file-invoice"></i> RESTO de INFORMES</h5>
            </div>
            <div class="card-body p-0">
                <div id="reportButtonsContainer" class="d-flex flex-column gap-2 align-items-start p-3">
                    
                    <!-- D.G. INFRAESTRUCTURAS X MERCADO -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <div class="input-group rpt-input-group-index">
                            <button class="btn rpt-btn-light rpt-btn-index rpt-btn-index-alone flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'mercados_dg')"
                                    aria-label="Ver informe D.G. Infraestructuras x Mercados">
                                D.G. Infraestructuras x Mercados
                            </button>
                        </div>
                    </div>

                    <!-- GERENCIAS -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <div class="input-group rpt-input-group-index">
                            <button class="btn rpt-btn-light rpt-btn-index rpt-btn-index-alone flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'gerencias')"
                                    aria-label="Ver informe Gerencias">
                                Gerencias
                            </button>
                        </div>
                    </div>

                    <!-- ACTIVIDADES OBJETIVOS -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <div class="input-group rpt-input-group-index">
                            <button class="btn rpt-btn-light rpt-btn-index rpt-btn-index-alone flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'actividades_objetivos')"
                                    aria-label="Ver informe Actividades Objetivos">
                                Actividades Objetivos
                            </button>
                        </div>
                    </div>

                    <!-- S.G. DELEGACIONES MERCADOS -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <div class="input-group rpt-input-group-index">
                            <button class="btn rpt-btn-light rpt-btn-index rpt-btn-index-alone flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'mercados_sg_delegaciones')"
                                    aria-label="Ver informe S.G. Delegaciones x Mercados">
                                S.G. Delegaciones x Mercados
                            </button>
                        </div>
                    </div>

                    <!-- RANKING CONTRATACIÓN NACIONAL + INTERNACIONAL -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <div class="input-group rpt-input-group-index">
                            <button class="btn rpt-btn-light rpt-btn-index rpt-btn-index-alone flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'ranking_contratacion_clientes')"
                                    data-mercado="Nacional"
                                    data-mostrar-titulo="false"
                                    aria-label="Ver informe Ranking Contratación Nacional">
                                Ranking Contratación Nacional
                            </button>
                        </div>
                        <div class="input-group rpt-input-group-index">
                            <button class="btn rpt-btn-light rpt-btn-index rpt-btn-index-alone flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'ranking_contratacion_clientes')"
                                    data-mercado="Internacional"
                                    data-mostrar-titulo="false"
                                    aria-label="Ver informe Ranking Contratación Internacional">
                                Ranking Contratación Internacional
                            </button>
                        </div>
                    </div>

                    <!-- CONTRATACIONES SIGNIFICATIVAS NACIONAL + INTERNACIONAL -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <div class="input-group rpt-input-group-index">
                            <button class="btn rpt-btn-light rpt-btn-index rpt-btn-index-alone flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'contrataciones_significativas_ri')"
                                    data-mercado="Nacional"
                                    data-mostrar-titulo="false"
                                    aria-label="Ver informe Contrataciones Significativas Nacional">
                                Contrataciones Significativas Nacional
                            </button>
                        </div>
                        <div class="input-group rpt-input-group-index">
                            <button class="btn rpt-btn-light rpt-btn-index rpt-btn-index-alone flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'contrataciones_significativas_ri')"
                                    data-mercado="Internacional"
                                    data-mostrar-titulo="false"
                                    aria-label="Ver informe Contrataciones Significativas Internacional">
                                Contrataciones Significativas Internacional
                            </button>
                        </div>
                    </div>

                    <!-- PAÍSES RELEVANTES (NACIONAL + INTERNACIONAL) -->
                    <div class="d-flex align-items-center gap-2 w-100">
                        <div class="input-group rpt-input-group-index">
                            <button class="btn rpt-btn-light rpt-btn-index rpt-btn-index-alone flex-fill text-start" type="button"
                                    onclick="cargarInforme(this, 'paises_all')"
                                    data-mostrar-titulo="false"
                                    aria-label="Ver informe Países Relevantes">
                                Países Relevantes
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ==================== CARD 4: OPCIONES DE GENERACIÓN ==================== -->
        <div class="card mb-4 rpt-index-card">
            <div class="card-header rpt-index-header">
                <h5 class="mb-0 text-uppercase" style="font-size: 0.85rem; letter-spacing: 1px;">
                    <i class="fas fa-cogs"></i> Opciones de Generación
                </h5>
            </div>
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-center gap-4 w-100 p-3 bg-light bg-opacity-50">
                    <div class="d-flex align-items-center gap-2">
                        <label class="form-check-label mb-0 rpt-checkbox-label text-muted" for="chkGenerarRPTPrincipalesObras">
                            Generar Contratación
                        </label>
                        <input class="form-check-input mt-0" type="checkbox"
                               id="chkGenerarRPTPrincipalesObras"
                               name="chkGenerarRPTPrincipalesObras">
                    </div>

                    <div class="d-flex align-items-center gap-2">
                        <label class="form-check-label mb-0 rpt-checkbox-label text-muted" for="chkGenerarRPTPrincipalesObrasAI">
                            Generar Contratación(AI)
                        </label>
                        <input class="form-check-input mt-0" type="checkbox"
                               id="chkGenerarRPTPrincipalesObrasAI"
                               name="chkGenerarRPTPrincipalesObrasAI">
                    </div>

                    <div class="d-flex align-items-center gap-2">
                        <label class="form-check-label mb-0 rpt-checkbox-label text-muted" for="chkGenerarRPTPrincipalesContrataciones">
                            Generar Contrataciones Significativas
                        </label>
                        <input class="form-check-input mt-0" type="checkbox"
                               id="chkGenerarRPTPrincipalesContrataciones"
                               name="chkGenerarRPTPrincipalesContrataciones">
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- MODAL LOGIN -->
<div class="modal" id="formLogin" tabindex="-1" role="dialog" aria-labelledby="formLoginLabel" aria-hidden="true"
    data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content login-custom-container p-3">
            <form id="loginForm">
                <div class="modal-body">
                    <div id="loginErrorMsg" class="alert alert-danger d-none" role="alert">
                    </div>

                    <div class="mb-4">
                        <label for="txtUser" class="login-label">Usuario:</label>
                        <input type="text" class="form-control login-input" id="txtUser" name="Username" required
                               value="anruiz"
                               aria-label="Nombre de usuario" aria-required="true">
                    </div>

                    <div class="mb-4">
                        <label for="txtPassword" class="login-label">Contraseña:</label>
                        <div class="position-relative">
                            <input type="password" class="form-control login-input pe-5" id="txtPassword" name="Password" 
                                   required
                                   value="Eagle999"
                                   placeholder="Contraseña"
                                   aria-label="Contraseña" aria-required="true">
                            <i class="fas fa-eye password-toggle-icon" id="togglePassword" title="Mostrar/Ocultar contraseña"></i>
                        </div>
                    </div>

                    <div class="mt-2">
                        <button type="submit" class="btn btn-login-custom" aria-label="Entrar al sistema">
                            Entrar
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL INFORME -->
<div class="modal fade" id="modalInforme" tabindex="-1" aria-labelledby="modalInformeLabel" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen">
        <div class="modal-content border-0">
            <div class="modal-header bg-primary text-white shadow-sm py-2 px-4 modal-header-report">
                <div class="d-flex align-items-center gap-2 modal-header-left">
                    <h5 class="modal-title mb-0" id="modalInformeTitulo">Cargando Informe...</h5>
                    <button type="button" class="btn btn-sm btn-outline-light" id="btnExportarPdf"
                            aria-label="Imprimir informe en PDF">
                        <i class="fas fa-file-pdf me-1" aria-hidden="true"></i> Imprimir PDF
                    </button>
                </div>

                <div class="d-flex align-items-center justify-content-center modal-header-center">
                    <div class="d-flex align-items-center d-none" id="ctrlPaginacion">
                        <button type="button" class="btn btn-sm btn-outline-light"
                                id="btnPagAnterior" disabled
                                aria-label="Ir a gerencia anterior" aria-disabled="true">
                            <i class="fas fa-chevron-left" aria-hidden="true"></i>
                        </button>
                        <span id="lblEstadoPaginacion" class="modal-pag-label mx-2"></span>
                        <button type="button" class="btn btn-sm btn-outline-light"
                                id="btnPagSiguiente" disabled
                                aria-label="Ir a siguiente gerencia" aria-disabled="true">
                            <i class="fas fa-chevron-right" aria-hidden="true"></i>
                        </button>
                    </div>
                </div>

                <div class="d-flex align-items-center justify-content-end modal-header-right">
                    <button type="button" class="btn-close btn-close-white"
                            data-bs-dismiss="modal" aria-label="Cerrar modal de informe"></button>
                </div>
            </div>
            <div class="modal-body modal-body-reports" id="modalInformeContenido">
                <div class="d-flex justify-content-center align-items-center h-100">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/informes/informes_base.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/informes/mercados.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/informes/contrataciones.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/informes/contrataciones_ai.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/informes/ranking_contratacion_clientes.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/informes/mercados_dg.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/informes/gerencias.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/informes/actividades_objetivos.css" asp-append-version="true" />
}

@section Scripts {
    <script type="module" src="~/js/index.js" asp-append-version="true"></script>
    <script src="~/js/informes/informes_manager.js" type="module" asp-append-version="true"></script>
}